@page "/collectorassignmentshuynqs/delete"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject NavigationManager NavigationManager
@using WasteCollection.Services.HuyNQ;
@using WasteCollection.Services.HuyNQ.DTOs;
@inject ICollectorAssignmentsHuyNqService CollectorAssignmentsHuyNqService

<PageTitle>Delete Assignment | Smart Waste Platform</PageTitle>

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-lg-8 col-xl-7">
        <div class="card border-0 shadow-xl rounded-4 overflow-hidden" style="border-top: 4px solid var(--color-danger) !important;">
            <!-- Danger Header -->
            <div class="bg-light p-4 border-bottom border-light text-center">
                <div class="d-flex flex-column align-items-center mb-3 mt-2">
                    <div class="rounded-circle d-flex justify-content-center align-items-center shadow-md mb-3" style="width: 64px; height: 64px; background: linear-gradient(145deg, var(--color-danger), #dc2626);">
                        <span class="bi bi-exclamation-triangle-fill fs-2 text-white"></span>
                    </div>
                    <h3 class="fw-bold mb-1 text-danger" style="font-family: 'Outfit', sans-serif; letter-spacing: -0.02em;">Delete Assignment</h3>
                    <p class="text-muted fw-medium mb-0" style="font-size: 0.95rem; max-width: 400px;">Are you entirely sure you want to permanently delete this record? This action cannot be reversed.</p>
                </div>
            </div>

            <!-- Details Body -->
            <div class="card-body p-4 p-md-5 bg-white">
                @if (collectorassignmentshuynq is null)
                {
                    <div class="d-flex justify-content-center flex-column align-items-center p-5">
                        <div class="spinner-border text-danger shadow-sm mb-3" role="status" style="width: 3rem; height: 3rem;"></div>
                        <span class="fw-semibold text-muted">Locating Record...</span>
                    </div>
                }
                else
                {
                    <div class="bg-danger-subtle p-4 rounded-4 border border-danger border-opacity-25 mb-5 shadow-xs">
                        <div class="row g-4">
                            <div class="col-sm-6">
                                <span class="text-danger small fw-bold text-uppercase d-block mb-1" style="letter-spacing: 0.05em;">Current Status</span>
                                <span class="badge bg-white text-danger border border-danger px-3 py-2 rounded-pill fw-bold shadow-sm" style="font-size: 0.85rem;">@collectorassignmentshuynq.Status</span>
                            </div>
                            <div class="col-sm-6">
                                <span class="text-danger small fw-bold text-uppercase d-block mb-1" style="letter-spacing: 0.05em;">Assigned Date</span>
                                <span class="fw-bold text-dark fs-6 d-block mt-2">@(collectorassignmentshuynq.AssignedDate?.ToString("MMM dd, yyyy HH:mm") ?? "-")</span>
                            </div>
                            <div class="col-sm-12">
                                <span class="text-danger small fw-bold text-uppercase d-block mb-1" style="letter-spacing: 0.05em;">Report Address</span>
                                <span class="fw-medium text-dark text-break bg-white px-3 py-2 rounded border border-danger border-opacity-25 d-inline-block shadow-sm">@collectorassignmentshuynq.Address</span>
                            </div>
                            @if (collectorassignmentshuynq.CollectedWeight != null)
                            {
                                <div class="col-sm-6">
                                    <span class="text-danger small fw-bold text-uppercase d-block mb-1" style="letter-spacing: 0.05em;">Expected Vol.</span>
                                    <span class="fw-bold text-dark fs-5 mt-2">@collectorassignmentshuynq.CollectedWeight kg</span>
                                </div>
                            }
                        </div>
                    </div>

                    <EditForm method="post" Model="collectorassignmentshuynq" OnValidSubmit="DeleteCollectorAssignmentsHuyNq" FormName="delete" Enhance>
                        <div class="d-flex flex-column-reverse flex-sm-row justify-content-center gap-3 pt-3">
                            <a href="/collectorassignmentshuynqs" class="btn btn-light px-5 py-3 fw-bold text-uppercase d-flex align-items-center justify-content-center shadow-xs" style="font-size: 0.85rem; letter-spacing: 0.05em;">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-danger px-5 py-3 fw-bold text-uppercase d-flex align-items-center justify-content-center shadow-md hover-lift" style="font-size: 0.85rem; letter-spacing: 0.05em;" disabled="@(collectorassignmentshuynq is null)">
                                <span class="bi bi-trash-fill me-2"></span> Confirm Delete
                            </button>
                        </div>
                    </EditForm>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private CollectorAssignmentsHuyNqGetDto? collectorassignmentshuynq;

    [SupplyParameterFromQuery]
    private Guid AssignmentId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        collectorassignmentshuynq ??= await CollectorAssignmentsHuyNqService.GetByIdAsync(AssignmentId);

        if (collectorassignmentshuynq is null)
        {
            NavigationManager.NotFound();
        }
    }

    private async Task DeleteCollectorAssignmentsHuyNq()
    {
        await CollectorAssignmentsHuyNqService.DeleteAsync(AssignmentId);
        NavigationManager.NavigateTo("/collectorassignmentshuynqs");
    }
}

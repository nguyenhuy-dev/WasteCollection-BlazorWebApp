@page "/collectorassignmentshuynqs/delete"
@inject NavigationManager NavigationManager
@using WasteCollection.Services.HuyNQ;
@using WasteCollection.Services.HuyNQ.DTOs;
@inject ICollectorAssignmentsHuyNqService CollectorAssignmentsHuyNqService

<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>CollectorAssignmentsHuyNq</h2>
    <hr />
    @if (collectorassignmentshuynq is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">ReportHuyNqid</dt>
            <dd class="col-sm-10">@collectorassignmentshuynq.ReportHuyNqid</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">AssignedDate</dt>
            <dd class="col-sm-10">@collectorassignmentshuynq.AssignedDate</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Status</dt>
            <dd class="col-sm-10">@collectorassignmentshuynq.Status</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ArrivalTime</dt>
            <dd class="col-sm-10">@collectorassignmentshuynq.ArrivalTime</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">CompletionTime</dt>
            <dd class="col-sm-10">@collectorassignmentshuynq.CompletionTime</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">CollectedWeight</dt>
            <dd class="col-sm-10">@collectorassignmentshuynq.CollectedWeight</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">ProofImageUrl</dt>
            <dd class="col-sm-10">@collectorassignmentshuynq.ProofImageUrl</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">EstimatedArrivalTime</dt>
            <dd class="col-sm-10">@collectorassignmentshuynq.EstimatedArrivalTime</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Notes</dt>
            <dd class="col-sm-10">@collectorassignmentshuynq.Notes</dd>
        </dl>
        <EditForm method="post" Model="collectorassignmentshuynq" OnValidSubmit="DeleteCollectorAssignmentsHuyNq" FormName="delete" Enhance>
            <button type="submit" class="btn btn-danger" disabled="@(collectorassignmentshuynq is null)">Delete</button> |
            <a href="/collectorassignmentshuynqs">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private CollectorAssignmentsHuyNqGetDto? collectorassignmentshuynq;

    [SupplyParameterFromQuery]
    private Guid AssignmentId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        collectorassignmentshuynq ??= await CollectorAssignmentsHuyNqService.GetByIdAsync(AssignmentId);

        if (collectorassignmentshuynq is null)
        {
            NavigationManager.NotFound();
        }
    }

    private async Task DeleteCollectorAssignmentsHuyNq()
    {
        await CollectorAssignmentsHuyNqService.DeleteAsync(AssignmentId);
        NavigationManager.NavigateTo("/collectorassignmentshuynqs");
    }
}

@page "/login"
@layout AuthLayout
@inject WasteCollection.Services.HuyNQ.SystemUserAccountService AccountService
@inject NavigationManager NavigationManager
@using WasteCollection.Services.HuyNQ.DTOs
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication.Cookies
@using Microsoft.AspNetCore.Authentication
@inject IHttpContextAccessor ThisHttpContext

<PageTitle>Sign In | Smart Waste Platform</PageTitle>

<div class="container-fluid min-vh-100 d-flex justify-content-center align-items-center position-relative login-bg">

    <!-- Abstract Background Art -->
    <div class="position-absolute w-100 h-100 overflow-hidden" style="pointer-events:none; z-index:0;">
        <div class="position-absolute bg-primary rounded-circle blur-bg"
             style="width:400px;height:400px;top:-100px;left:-100px;opacity:0.1;filter:blur(60px);">
        </div>

        <div class="position-absolute bg-success rounded-circle blur-bg"
             style="width:500px;height:500px;bottom:-150px;right:-100px;opacity:0.1;filter:blur(80px);">
        </div>
    </div>

    <div class="col-md-8 col-lg-5 col-xl-4 position-relative" style="z-index:1;">

        <div class="card border-0 shadow-2xl rounded-4 overflow-hidden glass-panel">
            <div class="card-body p-4 p-md-5">

                <div class="text-center mb-5">
                    <div class="rounded-circle d-flex justify-content-center align-items-center shadow-md mx-auto mb-4 logo-circle">
                        <span class="bi bi-recycle fs-1 text-white"></span>
                    </div>

                    <h3 class="fw-bold mb-1 title">Welcome Back</h3>
                    <p class="text-muted fw-medium small">Sign in to Smart Waste Collection Core</p>
                </div>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="alert alert-danger d-flex align-items-center border-0 shadow-sm rounded-3 p-3 mb-4">
                        <span class="bi bi-exclamation-octagon-fill me-2 fs-5"></span>
                        <div class="fw-semibold small">@ErrorMessage</div>
                    </div>
                }

                <EditForm Model="LoginDto" OnValidSubmit="HandleLogin" FormName="LoginForm">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="text-danger mb-3 fw-semibold small" />

                    <div class="mb-4">
                        <label class="form-label text-muted text-uppercase fw-bold label-text">Work Email</label>

                        <div class="input-group shadow-xs">
                            <span class="input-group-text bg-light border-end-0 py-3">
                                <i class="bi bi-envelope text-muted"></i>
                            </span>

                            <InputText class="form-control border-start-0 py-3 ps-0"
                                       @bind-Value="LoginDto.Email"
                                       placeholder="name@company.com"
                                       autocomplete="email" />
                        </div>
                    </div>

                    <div class="mb-5">

                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <label class="form-label text-muted text-uppercase fw-bold mb-0 label-text">Password</label>
                        </div>

                        <div class="input-group shadow-xs">
                            <span class="input-group-text bg-light border-end-0 py-3">
                                <i class="bi bi-shield-lock text-muted"></i>
                            </span>

                            <InputText type="password"
                                       class="form-control border-start-0 py-3 ps-0"
                                       @bind-Value="LoginDto.Password"
                                       autocomplete="current-password" />
                            
                        </div>

                    </div>

                    <div class="d-grid gap-3 mb-4">
                        <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-md login-btn">
                            Sign In
                            <span class="bi bi-arrow-right ms-2"></span>
                        </button>
                    </div>

                    <div class="d-flex align-items-center mb-4">
                        <div class="flex-grow-1 bg-light divider"></div>
                        <span class="px-3 text-muted fw-bold small">OR</span>
                        <div class="flex-grow-1 bg-light divider"></div>
                    </div>

                    <div class="d-grid">
                        <button type="button"
                                class="btn btn-light btn-lg fw-bold shadow-xs border text-muted d-flex align-items-center justify-content-center gap-2">
                            <span class="bi bi-google text-danger"></span>
                            Continue with Google
                        </button>
                    </div>

                </EditForm>

                <div class="text-center mt-5">

                    <div>
                        <a href="/" class="text-decoration-none text-muted fw-bold small">
                            <span class="bi bi-arrow-left me-1"></span>
                            Return to Home
                        </a>
                    </div>

                    <div class="mt-2">
                        <a href="#" class="text-primary fw-bold text-decoration-none small">
                            Forgot Password?
                        </a>
                    </div>

                </div>

            </div>
        </div>

        <div class="text-center mt-4">
            <span class="text-muted fw-semibold small">
                © @DateTime.Now.Year Smart Waste Systems Inc. All rights reserved.
            </span>
        </div>

    </div>

</div>

@code {
    [SupplyParameterFromForm]
    public LoginModel LoginDto { get; set; } = new();

    private string? ErrorMessage;

    private async Task HandleLogin()
    {
        ErrorMessage = null;

        try
        {
            var request = new LoginRequest(LoginDto.Email, LoginDto.Password);

            var user = await AccountService.LoginAsync(request);

            if (user == null)
            {
                ErrorMessage = "Invalid email or password.";
                return;
            }

            var claims = new List<Claim>
            {
                new(ClaimTypes.NameIdentifier, user.UserAccountId.ToString()),
                new(ClaimTypes.Name, user.FullName)
            };

            // Create Identity
            var identity = new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme);

            // Sign-in user
            if (ThisHttpContext.HttpContext != null)
            {
                await ThisHttpContext.HttpContext.SignInAsync(CookieAuthenticationDefaults.AuthenticationScheme, new ClaimsPrincipal(identity));
                NavigationManager.NavigateTo("/");
                return;
            }

            NavigationManager.NavigateTo("/login", true);
        }
        catch (Exception ex)
        {
            ErrorMessage = "An error occurred during login. Please try again.";
            Console.WriteLine($"Login Error: {ex.Message}");
        }
    }

    public class LoginModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Invalid email format")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;
    }

}


<style>

    .login-bg {
        background: linear-gradient(135deg,#f8fafc 0%,#e2e8f0 100%);
    }

    .shadow-2xl {
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);
    }

    .glass-panel {
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(16px);
    }

    .logo-circle {
        width: 72px;
        height: 72px;
        background: linear-gradient(145deg,var(--color-primary),#0ea5e9);
    }

    .title {
        color: var(--color-text-main);
        font-family: 'Outfit',sans-serif;
        letter-spacing: -0.02em;
    }

    .label-text {
        font-size: 0.75rem;
        letter-spacing: 0.1em;
    }

    .login-btn {
        letter-spacing: 0.05em;
        font-size: 0.9rem;
    }

    .divider {
        height: 1px;
    }

    body {
        overflow-x: hidden;
    }
</style>

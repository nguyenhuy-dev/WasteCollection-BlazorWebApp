@page "/collectorassignmentshuynqs"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer
@using WasteCollection.Entities.HuyNQ.Models
@using WasteCollection.Repositories.HuyNQ.Models
@using WasteCollection.Services.HuyNQ
@using WasteCollection.Services.HuyNQ.DTOs
@inject ICollectorAssignmentsHuyNqService CollectorAssignmentsHuyNqService
@inject NavigationManager NavigationManager

<PageTitle>Assignments | Smart Waste Platform</PageTitle>

<div class="container-fluid py-4 mb-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 pb-2 border-bottom border-light">
        <div>
            <h2 class="fw-bold mb-1" style="color: var(--color-text-main); font-family: 'Outfit', sans-serif; letter-spacing: -0.02em;">Assignments Grid</h2>
            <p class="text-muted mb-0 fw-medium" style="font-size: 0.9rem;">Manage and monitor collector responsibilities across the fleet.</p>
        </div>
        <div class="mt-3 mt-md-0">
            <a href="collectorassignmentshuynqs/create" class="btn btn-success rounded-pill px-4 shadow-sm hover-lift d-flex align-items-center gap-2">
                <span class="bi bi-plus-circle-fill"></span> Create Assignment
            </a>
        </div>
    </div>

    <!-- Search & Filter Area -->
    <div class="card mb-4 border-0 shadow-sm rounded-4 overflow-hidden" style="background: rgba(255, 255, 255, 0.85); backdrop-filter: blur(8px);">
        <div class="card-body p-4">
            <EditForm Model="SearchOptions" OnValidSubmit="PerformSearch" FormName="SearchAssignmentsForm">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label text-muted text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.05em;">Status</label>
                        <InputSelect @bind-Value="SearchOptions.Status" class="form-select border-0 shadow-xs">
                            <option value="">All Statuses</option>
                            <option value="Assigned">Assigned</option>
                            <option value="OnTheWay">On The Way</option>
                            <option value="Collected">Collected</option>
                            <option value="Cancelled">Cancelled</option>
                        </InputSelect>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.05em;">Collected Weight</label>
                        <InputNumber @bind-Value="SearchOptions.CollectedWeight" class="form-control border-0 shadow-xs" placeholder="Filter by Weight (kg)" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label text-muted text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.05em;">Assigned Date</label>
                        <InputDate @bind-Value="SearchOptions.AssignedDate" class="form-control border-0 shadow-xs" />
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button type="submit" class="btn btn-primary fw-bold w-100 shadow-sm">Filter Results</button>
                        <button type="button" class="btn btn-outline-secondary fw-bold px-3" @onclick="ClearSearch" @onclick:preventDefault="true" title="Clear Filters">
                            <span class="bi bi-x-lg">Clear</span>
                        </button>
                    </div>
                </div>
            </EditForm>
        </div>
    </div>

    <!-- Data Table Area -->
    <div class="card border-0 shadow-md rounded-4 overflow-hidden bg-white">
        <div class="table-responsive">
            @if (searchResult == null)
            {
                <div class="p-5 text-center d-flex flex-column align-items-center justify-content-center" style="min-height: 400px;">
                    <div class="spinner-border text-primary shadow-sm mb-3" role="status" style="width: 3rem; height: 3rem;">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span class="fw-semibold text-muted">Retrieving Data Grid...</span>
                </div>
            }
            else if (!searchResult.Items.Any())
            {
                <div class="p-5 text-center text-muted d-flex flex-column align-items-center justify-content-center" style="min-height: 400px;">
                    <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                        <span class="bi bi-inbox fs-1 text-secondary"></span>
                    </div>
                    <h4 class="fw-bold text-dark">No records found</h4>
                    <p>Adjust your search filters to see more results.</p>
                </div>
            }
            else
            {
                <table class="modern-table">
                    <thead>
                        <tr>
                            <th class="ps-4">Assigned Date</th>
                            <th>Status Badge</th>
                            <th>Arrival Time</th>
                            <th>Completion Time</th>
                            <th>Weight </th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in searchResult.Items)
                        {
                            <tr>
                                <td class="ps-4 fw-medium">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="rounded bg-light p-2 d-flex align-items-center justify-content-center shadow-xs">
                                            <span class="bi bi-calendar2-week text-primary"></span>
                                        </div>
                                        <span>@(item.AssignedDate?.ToString("MMM dd, yyyy HH:mm") ?? "-")</span>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge rounded-pill px-3 py-2 fw-bold @GetStatusBadgeClass(item.Status)" style="font-size: 0.75rem; border: 1px solid currentColor;">
                                        <span class="bi @GetStatusIcon(item.Status) me-1"></span> @item.Status
                                    </span>
                                </td>
                                <td><span class="text-muted">@(item.ArrivalTime?.ToString("MMM dd, yyyy HH:mm") ?? "-")</span></td>
                                <td><span class="text-muted">@(item.CompletionTime?.ToString("MMM dd, yyyy HH:mm") ?? "-")</span></td>
                                <td class="fw-bold text-dark">
                                    @(item.CollectedWeight.HasValue ? $"{item.CollectedWeight} kg" : "-")
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="@($"collectorassignmentshuynqs/details?assignmentid={item.AssignmentId}")" class="btn btn-sm btn-light text-primary hover-lift fw-bold px-3 rounded-pill shadow-xs" title="View Details">
                                            Details
                                        </a>
                                        <a href="@($"collectorassignmentshuynqs/edit?assignmentid={item.AssignmentId}")" class="btn btn-sm btn-light text-success hover-lift fw-bold px-3 rounded-pill shadow-xs" title="Edit Record">
                                            Edit
                                        </a>
                                        <a href="@($"collectorassignmentshuynqs/delete?assignmentid={item.AssignmentId}")" class="btn btn-sm btn-light text-danger hover-lift fw-bold px-3 rounded-pill shadow-xs" title="Delete Record">
                                            Remove
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
        
        <!-- Premium Pagination footer -->
        @if (searchResult != null && searchResult.TotalPages >= 1)
        {
            <div class="bg-light border-top border-light py-3 px-4 d-flex flex-column flex-sm-row justify-content-between align-items-center gap-3 rounded-bottom-4">
                <span class="text-muted fw-semibold" style="font-size: 0.85rem;">
                    Displaying Page <span class="text-dark">@searchResult.PageNumber</span> of <span class="text-dark">@searchResult.TotalPages</span> 
                    &nbsp;&bull;&nbsp; <span class="text-dark">@searchResult.TotalCount</span> Total Entries
                </span>
                
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-white border shadow-xs rounded-pill px-3 fw-bold @(searchResult.HasPrev ? "text-primary hover-lift" : "text-muted disabled")" @onclick="() => GoToPage(searchResult.PageNumber - 1)">
                        <span class="bi bi-chevron-left me-1"></span> Prev
                    </button>
                    
                    <div class="d-flex gap-1">
                        @for (int i = 1; i <= searchResult.TotalPages; i++)
                        {
                            var pageNum = i;
                            <button class="btn btn-sm rounded-circle d-flex align-items-center justify-content-center fw-bold transition-fast @(pageNum == searchResult.PageNumber ? "btn-primary shadow-sm" : "btn-light text-muted")" style="width: 32px; height: 32px;" @onclick="() => GoToPage(pageNum)">
                                @pageNum
                            </button>
                        }
                    </div>

                    <button class="btn btn-sm btn-white border shadow-xs rounded-pill px-3 fw-bold @(searchResult.HasNext ? "text-primary hover-lift" : "text-muted disabled")" @onclick="() => GoToPage(searchResult.PageNumber + 1)">
                        Next <span class="bi bi-chevron-right ms-1"></span>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private PaginatedResult<CollectorAssignmentsHuyNqGetAllDto>? searchResult;

    [SupplyParameterFromForm]
    public CollectorAssignmentsHuyNqSearchOptions SearchOptions { get; set; }

    protected override async Task OnInitializedAsync()
    {
        SearchOptions ??= new();

        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            searchResult = await CollectorAssignmentsHuyNqService.SearchAsync(SearchOptions);
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    private async Task PerformSearch()
    {
        SearchOptions.PageNumber = 1; // Reset to first page
        await LoadDataAsync();
    }

    private async Task ClearSearch()
    {
        SearchOptions = new CollectorAssignmentsHuyNqSearchOptions();
        await LoadDataAsync();
    }

    private async Task GoToPage(int page)
    {
        if (page >= 1 && (searchResult == null || page <= searchResult.TotalPages))
        {
            SearchOptions.PageNumber = page;
            await LoadDataAsync();
        }
    }

    private string GetStatusBadgeClass(string? status)
    {
        return status switch
        {
            "Assigned" => "bg-light text-primary",
            "OnTheWay" => "bg-warning-subtle text-warning-emphasis",
            "Collected" => "bg-success-subtle text-success",
            "Cancelled" => "bg-danger-subtle text-danger",
            _ => "bg-light text-secondary"
        };
    }

    private string GetStatusIcon(string? status)
    {
        return status switch
        {
            "Assigned" => "bi-clock-history",
            "OnTheWay" => "bi-truck",
            "Collected" => "bi-check2-all",
            "Cancelled" => "bi-x-circle",
            _ => "bi-record-circle"
        };
    }
}

@page "/collectorassignmentshuynqs/create"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using WasteCollection.Entities.HuyNQ.Models
@using WasteCollection.Services.HuyNQ
@using WasteCollection.Services.HuyNQ.DTOs
@inject NavigationManager NavigationManager
@inject ReportsHuyNqService ReportsHuyNqService
@inject ICollectorAssignmentsHuyNqService CollectorAssignmentsHuyNqService

<PageTitle>Create Assignment | Smart Waste Platform</PageTitle>

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-lg-8 col-xl-7">
        <div class="card border-0 shadow-xl rounded-4 overflow-hidden">
            <!-- Decorative Header -->
            <div class="bg-light p-4 border-bottom border-light">
                <div class="d-flex align-items-center mb-3">
                    <a href="/collectorassignmentshuynqs" class="btn btn-sm btn-white rounded-circle shadow-xs me-3 d-flex justify-content-center align-items-center hover-lift" style="width: 36px; height: 36px; color: var(--color-text-muted);">
                        <span class="bi bi-arrow-left"></span>
                    </a>
                    <div>
                        <h3 class="fw-bold mb-0" style="color: var(--color-text-main); font-family: 'Outfit', sans-serif; letter-spacing: -0.02em;">New Assignment</h3>
                        <span class="text-muted" style="font-size: 0.85rem;">Assign a route to a collector vehicle</span>
                    </div>
                </div>
            </div>

            <!-- Form Body -->
            <div class="card-body p-4 p-md-5 bg-white">
                <EditForm method="post" Model="CollectorAssignmentsHuyNq" OnValidSubmit="AddCollectorAssignmentsHuyNq" FormName="create" Enhance>
                    <DataAnnotationsValidator />
                    <ValidationSummary class="alert alert-danger mb-4 shadow-sm border-0 rounded-3 text-sm" />

                    @* <InputText @bind-Value="CollectorAssignmentsHuyNq.AssignmentId" hidden/> *@

                    <div class="mb-4">
                        <label for="reporthuynqid" class="form-label text-muted text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Report Address (Destination)</label>
                        <InputSelect id="reporthuynqid" @bind-Value="CollectorAssignmentsHuyNq.ReportHuyNqid" class="form-select border shadow-xs py-3">
                            <option value="">-- Select Report Address --</option>
                            @if (availableReports != null)
                            {
                                @foreach (var report in availableReports)
                                {
                                    <option value="@report.ReportId">@report.Address (@report.ReportDate?.ToString("MMM dd, yyyy"))</option>
                                }
                            }
                        </InputSelect>
                        <ValidationMessage For="() => CollectorAssignmentsHuyNq.ReportHuyNqid" class="validation-message" />
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label for="assigneddate" class="form-label text-muted text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Assigned Date</label>
                            <InputDate id="assigneddate" @bind-Value="CollectorAssignmentsHuyNq.AssignedDate" class="form-control border shadow-xs py-3" readonly/>
                            <ValidationMessage For="() => CollectorAssignmentsHuyNq.AssignedDate" class="validation-message" />
                        </div>
                        <div class="col-md-6">
                            <label for="status" class="form-label text-muted text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Collection Status</label>
                            <InputSelect id="status" @bind-Value="CollectorAssignmentsHuyNq.Status" class="form-select border shadow-xs py-3">
                                <option value="Assigned">Assigned</option>
                                <option value="OnTheWay">On The Way</option>
                                <option value="Collected">Collected</option>
                                <option value="Cancelled">Cancelled</option>
                            </InputSelect>
                            <ValidationMessage For="() => CollectorAssignmentsHuyNq.Status" class="validation-message" />
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label for="estimatedarrivaltime" class="form-label text-muted text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Est. Arrival Time</label>
                            <InputDate id="estimatedarrivaltime" @bind-Value="CollectorAssignmentsHuyNq.EstimatedArrivalTime" class="form-control border shadow-xs py-3" />
                            <ValidationMessage For="() => CollectorAssignmentsHuyNq.EstimatedArrivalTime" class="validation-message" />
                        </div>
                        <div class="col-md-6">
                            <label for="collectedweight" class="form-label text-muted text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Expected Vol. (kg)</label>
                            <InputNumber id="collectedweight" @bind-Value="CollectorAssignmentsHuyNq.CollectedWeight" class="form-control border shadow-xs py-3" placeholder="0.00" />
                            <ValidationMessage For="() => CollectorAssignmentsHuyNq.CollectedWeight" class="validation-message" />
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-md-6">
                            <label for="arrivaltime" class="form-label text-muted text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Actual Arrival Time</label>
                            <InputDate id="arrivaltime" @bind-Value="CollectorAssignmentsHuyNq.ArrivalTime" class="form-control border shadow-xs py-3" />
                            <ValidationMessage For="() => CollectorAssignmentsHuyNq.ArrivalTime" class="validation-message" />
                        </div>
                        <div class="col-md-6">
                            <label for="completiontime" class="form-label text-muted text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Completion Time</label>
                            <InputDate id="completiontime" @bind-Value="CollectorAssignmentsHuyNq.CompletionTime" class="form-control border shadow-xs py-3" />
                            <ValidationMessage For="() => CollectorAssignmentsHuyNq.CompletionTime" class="validation-message" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label for="proofimageurl" class="form-label text-muted text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Proof Image URL</label>
                        <div class="input-group shadow-xs">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-link-45deg text-muted"></i></span>
                            <InputText id="proofimageurl" @bind-Value="CollectorAssignmentsHuyNq.ProofImageUrl" class="form-control border-start-0 py-3 ps-0" placeholder="https://..." />
                        </div>
                        <ValidationMessage For="() => CollectorAssignmentsHuyNq.ProofImageUrl" class="validation-message" />
                    </div>

                    <div class="mb-5">
                        <label for="notes" class="form-label text-muted text-uppercase fw-bold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Additional Notes</label>
                        <InputTextArea id="notes" @bind-Value="CollectorAssignmentsHuyNq.Notes" class="form-control border shadow-xs py-3" rows="3" placeholder="Routing details, hazards, etc..." />
                        <ValidationMessage For="() => CollectorAssignmentsHuyNq.Notes" class="validation-message" />
                    </div>

                    <div class="d-flex flex-column-reverse flex-sm-row justify-content-end gap-3 pt-4 border-top border-light">
                        <a href="/collectorassignmentshuynqs" class="btn btn-outline-secondary px-4 py-2 fw-bold text-uppercase" style="font-size: 0.85rem; letter-spacing: 0.05em;">Cancel</a>
                        <button type="submit" class="btn btn-primary px-5 py-2 shadow-md hover-lift fw-bold text-uppercase d-flex align-items-center gap-2" style="font-size: 0.85rem; letter-spacing: 0.05em;">
                            Create Record <span class="bi bi-arrow-right"></span>
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm]
    private CollectorAssignmentsHuyNqCreatedDto CollectorAssignmentsHuyNq { get; set; } = new();

    private List<ReportsHuyNq>? availableReports;

    protected override async Task OnInitializedAsync()
    {
        availableReports = await ReportsHuyNqService.GetAllAsync();
        CollectorAssignmentsHuyNq.AssignmentId = Guid.CreateVersion7();
        CollectorAssignmentsHuyNq.AssignedDate = DateTime.Now; // Default value
    }

    private async Task AddCollectorAssignmentsHuyNq()
    {
        await CollectorAssignmentsHuyNqService.CreateAsync(CollectorAssignmentsHuyNq);
        NavigationManager.NavigateTo("/collectorassignmentshuynqs");
    }
}